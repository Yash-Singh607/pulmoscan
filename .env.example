# Copy to `.env` and adjust.

# Dataset / artifact locations
CXR_DATA_DIR=data/chest_xray
CXR_CHECKPOINT_DIR=checkpoints
CXR_OUTPUT_DIR=outputs

# DataLoader tuning (set CXR_NUM_WORKERS=0 on Windows if you hit issues)
CXR_BATCH_SIZE=32
CXR_NUM_WORKERS=0

# Serving: checkpoint loaded by the FastAPI app
CXR_CHECKPOINT_PATH=checkpoints/best_model.pth
CXR_MODEL_ID=default

# Monte-Carlo Dropout passes for uncertainty (0 disables; higher = slower)
CXR_MC_PASSES=10

# Upload limit (MB)
CXR_MAX_UPLOAD_MB=15

# API security (optional). Comma-separated keys; empty = auth disabled.
CXR_API_KEYS=
# Requests per minute per IP (0 disables rate limiting)
CXR_RATE_LIMIT=120

# JWT auth (hospital mode). Leave empty to disable auth for local demos.
CXR_JWT_SECRET=
# username:password:role (roles: viewer, clinician, admin)
CXR_USERS=clinician:changeme:clinician,admin:changeme:admin

# Logging level: DEBUG | INFO | WARNING | ERROR
CXR_LOG_LEVEL=INFO
